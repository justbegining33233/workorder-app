// ─────────────────────────────────────────────────────────────────
// PAYROLL & SCHEDULING MODELS
// ─────────────────────────────────────────────────────────────────

// Scheduled shifts for team members
model Shift {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  techId String
  tech   Tech   @relation(fields: [techId], references: [id], onDelete: Cascade)

  date      DateTime // The date of the shift (UTC midnight)
  startTime String   // "08:00" 24-hour format
  endTime   String   // "17:00" 24-hour format
  shiftType String   @default("regular") // regular, on-call, overtime, training
  position  String?  // e.g. "Lead Tech", "Service Advisor"
  notes     String?

  // Status
  status          String    @default("scheduled") // scheduled, confirmed, no-show, late, worked, cancelled
  confirmedAt     DateTime?
  actualClockIn   DateTime?
  actualClockOut  DateTime?
  lateMinutes     Int       @default(0)
  earlyDepartureMins Int    @default(0)

  // Swap tracking
  swapRequests ShiftSwapRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([techId])
  @@index([date])
  @@map("shifts")
}

// Shift swap requests between employees
model ShiftSwapRequest {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  shiftId     String
  shift       Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requesterId String
  requester   Tech   @relation("SwapRequester", fields: [requesterId], references: [id])
  targetId    String?
  target      Tech?  @relation("SwapTarget", fields: [targetId], references: [id])

  reason       String?
  status       String    @default("pending") // pending, approved, denied, withdrawn
  approvedById String?
  approvedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([requesterId])
  @@map("shift_swap_requests")
}

// PTO / Leave requests
model LeaveRequest {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  techId String
  tech   Tech   @relation(fields: [techId], references: [id], onDelete: Cascade)

  leaveType  String   // pto, vacation, sick, personal, unpaid, bereavement, jury
  startDate  DateTime
  endDate    DateTime
  totalHours Float    @default(0)
  reason     String?

  status       String    @default("pending") // pending, approved, denied, withdrawn
  approvedById String?
  approvedAt   DateTime?
  deniedReason String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([techId])
  @@index([status])
  @@map("leave_requests")
}

// Pay periods (weekly, biweekly, etc.)
model PayPeriod {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  periodType  String   @default("biweekly") // weekly, biweekly, semimonthly, monthly
  startDate   DateTime
  endDate     DateTime
  payDate     DateTime?
  status      String   @default("open") // open, processing, approved, paid, locked

  // Totals (computed when period is run)
  totalGross       Float @default(0)
  totalNet         Float @default(0)
  totalTaxes       Float @default(0)
  totalDeductions  Float @default(0)
  totalOvertimePay Float @default(0)
  employeeCount    Int   @default(0)

  notes     String?
  processedAt DateTime?
  processedBy String?

  payStubs PayStub[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([status])
  @@map("pay_periods")
}

// Individual employee pay stubs per period
model PayStub {
  id          String    @id @default(cuid())
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  techId      String
  tech        Tech      @relation(fields: [techId], references: [id], onDelete: Cascade)
  payPeriodId String
  payPeriod   PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)

  // Hours breakdown
  regularHours    Float @default(0)
  overtimeHours   Float @default(0)
  doubleTimeHours Float @default(0)
  ptoHours        Float @default(0)
  sickHours       Float @default(0)
  holidayHours    Float @default(0)

  // Pay breakdown
  regularPay    Float @default(0)
  overtimePay   Float @default(0)
  doubleTimePay Float @default(0)
  ptoPay        Float @default(0)
  bonusPay      Float @default(0)
  reimbursements Float @default(0)
  grossPay      Float @default(0)

  // Deductions
  federalTax     Float @default(0)
  stateTax       Float @default(0)
  socialSecurity Float @default(0)
  medicare       Float @default(0)
  healthInsurance Float @default(0)
  retirement401k Float @default(0)
  otherDeductions Float @default(0)
  totalDeductions Float @default(0)

  netPay Float @default(0)

  // YTD totals
  ytdGross    Float @default(0)
  ytdTaxes    Float @default(0)
  ytdNet      Float @default(0)

  status    String    @default("draft") // draft, approved, paid
  paidAt    DateTime?
  paidVia   String?   // direct-deposit, check, cash
  checkNumber String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([techId])
  @@index([payPeriodId])
  @@map("pay_stubs")
}

// Shop overtime rules configuration
model OvertimeRule {
  id     String @id @default(cuid())
  shopId String @unique
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Weekly OT
  weeklyOvertimeEnabled   Boolean @default(true)
  weeklyOvertimeThreshold Float   @default(40) // hours
  overtimeMultiplier      Float   @default(1.5)

  // Daily OT (California-style)
  dailyOvertimeEnabled   Boolean @default(false)
  dailyOvertimeThreshold Float   @default(8) // hours in a day
  dailyOTMultiplier      Float   @default(1.5)

  // Double time
  doubleTimeEnabled   Boolean @default(false)
  doubleTimeThreshold Float   @default(12) // hours in a day OR weekly hours
  doubleTimeMultiplier Float  @default(2.0)

  // 7th day rule (California)
  seventhDayRule Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("overtime_rules")
}

// Monthly report snapshots per shop (for /shop/reports)
model ShopMonthlyReport {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  year  Int // e.g. 2026
  month Int // 1-12

  totalRevenue    Float  @default(0)
  totalJobs       Int    @default(0)
  completedJobs   Int    @default(0)
  pendingJobs     Int    @default(0)
  avgJobValue     Float  @default(0)
  topServicesJson String @default("[]") // JSON array of {service, count, revenue}

  frozenAt  DateTime? // Set when month is over and snapshot is locked
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())

  @@unique([shopId, year, month])
  @@index([shopId])
  @@map("shop_monthly_reports")
}

// ─── Photo Gallery ────────────────────────────────────────────────────────────
// Persists metadata for photos uploaded via /api/photos.
// Actual image binary lives in Cloudinary; only the URL + metadata go here.
model Photo {
  id          String   @id @default(cuid())
  url         String
  filename    String?
  caption     String?
  workOrderId String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  @@index([workOrderId])
  @@map("photos")
}

// ─── Portal Chat ──────────────────────────────────────────────────────────────
// Persists staff-facing (tech / manager) portal chat messages.
// channelId = "global" for broadcast channels, "pair:<id1>:<id2>" for DMs.
model PortalChatMessage {
  id        String   @id @default(cuid())
  role      String   // 'tech' | 'manager' | 'shared'
  channelId String   @default("global")
  sender    String
  body      String
  timestamp DateTime @default(now())

  @@index([role, channelId])
  @@map("portal_chat_messages")
}

// ─── Tenant ───────────────────────────────────────────────────────────────────
model Tenant {
  id             String   @id @default(cuid())
  companyName    String
  subdomain      String   @unique
  logo           String?
  contactEmail   String
  contactPhone   String
  street         String?
  city           String?
  state          String?
  zip            String?
  plan           String   @default("free") // free | basic | pro | enterprise
  planStatus     String   @default("active") // active | suspended | cancelled
  planStartDate  DateTime @default(now())
  planRenewalDate DateTime?
  maxUsers       Int      @default(5)
  maxWorkOrders  Int      @default(100)
  timezone       String   @default("America/New_York")
  currency       String   @default("USD")
  businessStart  String   @default("08:00")
  businessEnd    String   @default("17:00")
  emailNotifs    Boolean  @default(true)
  smsNotifs      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("tenants")
}

// ─── Vendor ───────────────────────────────────────────────────────────────────
model Vendor {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  contactName   String   @default("")
  phone         String   @default("")
  email         String   @default("")
  website       String   @default("")
  category      String   @default("parts") // parts | fluids | tires | tools | other
  accountNumber String   @default("")
  paymentTerms  String   @default("Net 30")
  rating        Int      @default(0)
  notes         String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("vendors")
}

// ─── Work Order Template ──────────────────────────────────────────────────────
model WorkOrderTemplate {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  serviceType   String   @default("")
  description   String   @default("")
  repairs       String[] @default([])
  maintenance   String[] @default([])
  estimatedCost Float    @default(0)
  laborHours    Float    @default(0)
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("workorder_templates")
}

// ─── Shop Location ────────────────────────────────────────────────────────────
model ShopLocation {
  id       String  @id @default(cuid())
  shopId   String
  name     String
  address  String  @default("")
  city     String  @default("")
  state    String  @default("")
  zip      String  @default("")
  phone    String  @default("")
  email    String  @default("")
  isMain   Boolean @default(false)
  status   String  @default("active") // active | inactive
  notes    String  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("shop_locations")
}

// ─── API Keys ─────────────────────────────────────────────────────────────────
model ApiKey {
  id       String  @id @default(cuid())
  shopId   String
  name     String  // "Production Key", "Staging Key", etc.
  keyHash  String  @unique // SHA-256 hash of the raw key
  prefix   String  // First 8 chars of the key for identification (ft_live_xxxx...)
  scopes   String  @default("read") // comma-separated: read, write, workorders, inventory, etc.

  lastUsedAt DateTime?
  expiresAt  DateTime?
  revoked    Boolean   @default(false)
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([keyHash])
  @@map("api_keys")
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────
model Webhook {
  id     String @id @default(cuid())
  shopId String

  url    String // Endpoint to call
  secret String // HMAC signing secret
  events String // Comma-separated: workorder.created, workorder.updated, payment.received, etc.
  active Boolean @default(true)

  lastTriggeredAt DateTime?
  lastStatus      Int?       // HTTP status of last delivery
  failureCount    Int        @default(0) // Consecutive failures (auto-disable at 10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@map("webhooks")
}

// ─── Permissions ──────────────────────────────────────────────────────────────
model Permission {
  id     String @id @default(cuid())
  shopId String

  // Who: either a techId or a role name (tech, manager)
  techId String?
  role   String? // If set, applies to all users with this role in the shop

  // What: specific permission keys
  permission String // e.g. "workorders.create", "inventory.edit", "payroll.view", "settings.manage"
  allowed    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, techId, permission])
  @@index([shopId])
  @@index([techId])
  @@map("permissions")
}

model Campaign {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name       String
  type       String   // "email" | "sms" | "both"
  subject    String?  // Email subject
  body       String   // Message body (HTML for email, plain for SMS)
  status     String   @default("draft") // "draft" | "sending" | "sent" | "failed"
  recipientCount Int  @default(0)
  sentCount  Int      @default(0)
  failedCount Int     @default(0)
  sentAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopId])
  @@map("campaigns")
}
