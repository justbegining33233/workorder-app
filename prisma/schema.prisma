// Recurring Work Order schedules
model RecurringWorkOrder {
  id String @id @default(cuid())

  // Who scheduled it
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  // What to do
  title            String // e.g. "Oil Change"
  issueDescription String
  vehicleType      String @default("car")
  serviceLocation  String @default("in-shop")

  // Recurrence
  frequency String // weekly | biweekly | monthly | quarterly | annually
  nextRunAt DateTime // When the next work order should be created
  lastRunAt DateTime? // When the last work order was created

  // Template values carried into each new work order
  estimatedCost Float?
  priority      String  @default("medium")
  notes         String?

  active           Boolean @default(true)
  requiresApproval Boolean @default(true) // If true, customer must confirm before WO is created

  // Reminder tracking — prevents double-sending
  reminder14SentAt DateTime? // When the 14-day reminder was last sent
  reminder7SentAt  DateTime? // When the 7-day reminder was last sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([customerId])
  @@index([nextRunAt])
  @@map("recurring_work_orders")
}

