{
  "name": "workorder-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:socket": "node socket-server.js",
    "dev:full": "npm run dev:socket & npm run dev",
    "rehash-passwords": "node -r dotenv/config scripts/rehash-plaintext-passwords.js",
    "verify-login": "node -r dotenv/config scripts/verify-login-cli.js",
    "prepare": "husky install",
    "build": "node ./scripts/check-database.js && node ./scripts/prisma-safe-generate.js && cross-env NODE_OPTIONS=--max-old-space-size=4096 next build --webpack",
    "postinstall": "node ./scripts/prisma-safe-generate.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:integration": "jest --testPathPattern=integration --passWithNoTests",
    "test:e2e:ci": "playwright test --project=chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:ci && npm run test:e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "start": "NODE_ENV=production node server.js",
    "start:next": "NODE_ENV=production next start",
    "lint": "eslint",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/motion": "^8.0.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/status-bar": "^8.0.1",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.42.0",
    "@upstash/redis": "^1.36.3",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.8.0",
    "dotenv": "^16.6.1",
    "express-rate-limit": "^8.2.1",
    "isomorphic-dompurify": "^3.5.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "launchdarkly-js-client-sdk": "^3.9.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "nodemailer": "^7.0.12",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.6.0",
    "resend": "^6.9.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.1.0",
    "twilio": "^5.12.2",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.33",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/speakeasy": "^2.0.10",
    "@types/web-push": "^3.6.4",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "baseline-browser-mapping": "^2.9.19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "husky": "^8.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.3",
    "webpack-bundle-analyzer": "^5.1.1"
  }
}
